[importlinter]
root_packages =
    api
    core
    services
    models
    domain
    infra
include_external_packages = True

# Enforced in Phase 1 (Task 8). The no-core->api contract is KEPT with 0 broken
# after Tasks 3-4 removed all api.* imports from core/device_manager.py.
#
# NOTE: A no-infra->api contract is intentionally NOT added here. The file
# infra/device/wifi_tunnel.py still contains a lazy import of api.device._tunnels
# (Task-7-deferred intermediate). That contract is deferred to Phase 2.
[importlinter:contract:no-core-imports-api]
name = Core must not import API
type = forbidden
source_modules =
    core
forbidden_modules =
    api

# Phase 2 (Group 1): services must not import fastapi. ENFORCED at end of
# Group 1 Task 4 — services/geocoding.py raises GeocodeError instead of
# HTTPException; the api boundary re-maps it. Contract is KEPT (0 broken).
[importlinter:contract:no-services-imports-fastapi]
name = Services must not import FastAPI
type = forbidden
source_modules =
    services
forbidden_modules =
    fastapi

# Phase 2 (Group 3, Task 14): ENFORCED. Tasks 12-13 relocated tunnel state
# (_tunnels, _tunnels_lock, _tunnel_watchdogs) and attempt_tunnel_restart out
# of infra/device/wifi_tunnel.py, removing the last infra->api import edge.
# Contract flipped from report-only to enforced here (Task 14). 3 kept, 0 broken.
[importlinter:contract:no-infra-imports-api]
name = Infra must not import API
type = forbidden
source_modules =
    infra
forbidden_modules =
    api

# Phase 2 (Group 4, Task 19): ENFORCED. Tasks 15-18 removed all cross-module
# api->api imports (api.device, api.location, api.cloud_sync no longer import
# api.websocket; instead they use the injected EventPublisher). The sole
# sanctioned exception is the DI shim: any api.* module may import api.deps
# so that FastAPI Depends() wiring works. Contract enforced here (Task 19).
# 4 kept, 0 broken.
#
# Note: import-linter's `forbidden` type rejects source == forbidden when modules
# share descendants. We use the `independence` type instead: it checks that none
# of the listed modules imports any other. The api.deps shim is exempted via
# ignore_imports so that DI wiring (api.device -> api.deps, api.cloud_sync ->
# api.deps) is allowed. unmatched_ignore_imports_alerting = none suppresses
# warnings for ignore_imports entries that don't match any actual import.
[importlinter:contract:no-api-imports-api]
name = API modules must not import each other
type = independence
modules =
    api.bookmarks
    api.cloud_sync
    api.deps
    api.device
    api.geocode
    api.location
    api.phone_control
    api.recent
    api.route
    api.system
    api.websocket
ignore_imports =
    api.bookmarks -> api.deps
    api.device -> api.deps
    api.cloud_sync -> api.deps
    api.location -> api.deps
    api.route -> api.deps
unmatched_ignore_imports_alerting = none
