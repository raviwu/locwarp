[importlinter]
root_packages =
    api
    core
    services
    models

# Phase 1 will add service-layer contracts and flip these to enforced
# (assert returncode == 0 in test_import_linter.py). For now, violations
# are expected and the test runs in report-only mode.
[importlinter:contract:no-core-imports-api]
name = Core must not import API
type = forbidden
source_modules =
    core
forbidden_modules =
    api
