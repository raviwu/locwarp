[importlinter]
root_packages =
    api
    core
    services
    models
    domain
    infra
include_external_packages = True

# Enforced in Phase 1 (Task 8). The no-core->api contract is KEPT with 0 broken
# after Tasks 3-4 removed all api.* imports from core/device_manager.py.
[importlinter:contract:no-core-imports-api]
name = Core must not import API
type = forbidden
source_modules =
    core
forbidden_modules =
    api

# Phase 2 (Group 1): services must not import fastapi. ENFORCED at end of
# Group 1 Task 4 — services/geocoding.py raises GeocodeError instead of
# HTTPException; the api boundary re-maps it. Contract is KEPT (0 broken).
#
# Group 5b (Task 27): CloudSyncService deliberately raises HTTPException
# (400/500) to preserve the frozen cloud-sync HTTP status surface — that is a
# sanctioned retained fastapi import, whitelisted below. The spec-mandated
# domain-error fold is the geocode path ONLY. (This ignore-list entry is
# documented as Task-29-owned; it is added here because Task 27 lands the
# import and the import-linter tests assert exit-0, so it must stay green.)
[importlinter:contract:no-services-imports-fastapi]
name = Services must not import FastAPI
type = forbidden
source_modules =
    services
forbidden_modules =
    fastapi
ignore_imports =
    services.cloud_sync_service -> fastapi
unmatched_ignore_imports_alerting = none

# Phase 2 (Group 3, Task 14): ENFORCED. Tasks 12-13 relocated tunnel state
# (_tunnels, _tunnels_lock, _tunnel_watchdogs) and attempt_tunnel_restart out
# of infra/device/wifi_tunnel.py, removing the last infra->api import edge.
# Contract flipped from report-only to enforced here (Task 14). 3 kept, 0 broken.
[importlinter:contract:no-infra-imports-api]
name = Infra must not import API
type = forbidden
source_modules =
    infra
forbidden_modules =
    api

# Phase 2 (Group 4, Task 19): ENFORCED. Tasks 15-18 removed all cross-module
# api->api imports (api.device, api.location, api.cloud_sync no longer import
# api.websocket; instead they use the injected EventPublisher). The sole
# sanctioned exception is the DI shim: any api.* module may import api.deps
# so that FastAPI Depends() wiring works. Contract enforced here (Task 19).
# 4 kept, 0 broken.
#
# Note: import-linter's `forbidden` type rejects source == forbidden when modules
# share descendants. We use the `independence` type instead: it checks that none
# of the listed modules imports any other. The api.deps shim is exempted via
# ignore_imports so that DI wiring (api.device -> api.deps, api.cloud_sync ->
# api.deps) is allowed. unmatched_ignore_imports_alerting = none suppresses
# warnings for ignore_imports entries that don't match any actual import.
[importlinter:contract:no-api-imports-api]
name = API modules must not import each other
type = independence
modules =
    api.bookmarks
    api.cloud_sync
    api.deps
    api.device
    api.geocode
    api.location
    api.phone_control
    api.recent
    api.route
    api.system
    api.websocket
ignore_imports =
    api.bookmarks -> api.deps
    api.device -> api.deps
    api.cloud_sync -> api.deps
    api.geocode -> api.deps
    api.location -> api.deps
    api.phone_control -> api.deps
    api.route -> api.deps
unmatched_ignore_imports_alerting = none

# Phase 2 (Group 5b, Task 30): ENFORCED. The global cycle-gate — api/* must
# not import the composition root (main.py). After every Group 5a/5b sweep
# removed all `from main import ...` sites, this forbidden contract locks the
# invariant so the api->main->api cycle can never reform. KEPT, 0 broken.
#
# NOTE: `main` is NOT added to root_packages. main.py is a bare top-level
# MODULE, not a package (no __init__.py), and grimp's packagefinder raises
# NotATopLevelModule for bare modules — adding it to root_packages crashes
# lint-imports (exit 1, no contracts analyzed). With include_external_packages
# = True, grimp still resolves `main` as a forbidden external target reachable
# from the scanned api/* sources, so the contract is fully enforced.
[importlinter:contract:no-api-imports-main]
name = API must not import main
type = forbidden
source_modules =
    api
forbidden_modules =
    main

# Phase 3 (Task 1): ENFORCED from the start of Phase 3. domain/ is the pure
# inner ring (movement.py + events.py + errors.py + ports/) and must import
# stdlib + pydantic ONLY. `models` is intentionally NOT forbidden — it is pure
# pydantic schema and is an allowed inward dep until models relocate into
# domain/ in a later phase. This gate guards the Phase-3 extractions: any
# accidental domain -> core/services/api/infra/fastapi import fails CI.
# domain shares no descendants with the forbidden set, so `forbidden` is correct.
[importlinter:contract:no-domain-imports-outer]
name = Domain must not import outer rings
type = forbidden
source_modules =
    domain
forbidden_modules =
    core
    services
    api
    infra
    fastapi

# Phase 4a (Task 7): ENFORCED. infra/ adapters (device, events, persistence)
# are I/O edges, never HTTP routers — they must not import FastAPI. Passes as-is
# (the new infra/persistence/json_store.py imports stdlib + services.json_safe +
# domain.store_merge only). 7 kept, 0 broken.
[importlinter:contract:no-infra-imports-fastapi]
name = Infra must not import FastAPI
type = forbidden
source_modules =
    infra
forbidden_modules =
    fastapi
